{
  "name": "@sudobility/mogulgame_app",
  "private": true,
  "license": "BUSL-1.1",
  "version": "1.0.100",
  "type": "module",
  "scripts": {
    "dev": "bun run process:static && vite",
    "seo:fetch": "curl -fsSL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/generate-seo-assets-v2.mjs -o /tmp/generate-seo-assets.mjs",
    "build": "bun run process:static && bun run seo:fetch && node /tmp/generate-seo-assets.mjs public && tsc -b && vite build && node /tmp/generate-seo-assets.mjs dist",
    "generate:sitemap": "bun run seo:fetch && node /tmp/generate-seo-assets.mjs public",
    "prerender": "node scripts/prerender.mjs",
    "prerender:install": "bunx playwright install --with-deps chromium",
    "generate": "bun run process:static && bun run generate:sitemap && bun run prerender:install && bun run prerender",
    "process:static": "tsx scripts/process-static-files.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "localize": "SCRIPT=$(mktemp) && curl -fsSL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/localize_batch.cjs -o $SCRIPT && node $SCRIPT ./public/locales https://api.whisperly.dev/api/v1/translate/jie9cytr/starter --word-limit 40 && rm -f $SCRIPT && prettier . --write",
    "localized": "node scripts/localization_verify.cjs",
    "verify": "bun run typecheck && bun run lint && bun run format:check"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sudobility/auth-components": "^1.0.11",
    "@sudobility/auth_lib": "^0.0.82",
    "@sudobility/automotive-components": "^2.0.12",
    "@sudobility/building_blocks": "^0.0.272",
    "@sudobility/components": "^5.0.96",
    "@sudobility/design": "^1.1.46",
    "@sudobility/devops-components": "^2.0.19",
    "@sudobility/di": "^1.5.58",
    "@sudobility/di_web": "^0.1.209",
    "@sudobility/entity_client": "^0.0.36",
    "@sudobility/mogulgame_client": "^0.0.31",
    "@sudobility/mogulgame_lib": "^0.0.29",
    "@sudobility/mogulgame_types": "^0.0.22",
    "@sudobility/seo_lib": "^0.0.33",
    "@sudobility/subscription-components": "^1.0.31",
    "@sudobility/subscription_lib": "^0.0.44",
    "@sudobility/types": "^1.9.62",
    "@tanstack/react-query": "^5.90.5",
    "@vis.gl/react-google-maps": "^1.8.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.4.0",
    "i18next": "^25.8.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "playwright": "^1.60.0",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sudobility-usf/starter_app.git"
  }
}
